{
  "version": 2,
  "name": "ask-ya-cham-quantum-platform",
  "buildCommand": "cd apps/web && npm run build",
  "installCommand": "npm install && cd apps/web && npm install",
  "outputDirectory": "apps/web/.next",
  "public": true,
  "git": {
    "deploymentEnabled": {
      "main": true
    },
    "autoAlias": true
  },
  "github": {
    "silent": false,
    "autoAlias": true
  },
  "env": {
    "NODE_ENV": "production",
    "SERVER_TIMEOUT": "30000",
    "REQUEST_TIMEOUT": "25000",
    "KEEP_ALIVE_TIMEOUT": "65000",
    "HEADERS_TIMEOUT": "66000"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  },
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "regions": ["iad1"],
  "framework": "nextjs"
}