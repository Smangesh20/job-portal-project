# Error Handling and Validation Feature Flags
# Set to 'true' to enable features, 'false' or omit to disable

# Core error handling features
ENHANCED_ERROR_HANDLING=false
STRUCTURED_LOGGING=false
INPUT_VALIDATION=false

# Advanced features
ERROR_ANALYTICS=false
RATE_LIMITING=false
CORRELATION_TRACKING=false

# Authentication enhancements
ENHANCED_AUTH_ERRORS=false
OAUTH_INTEGRATION=false

# File upload enhancements
ENHANCED_FILE_VALIDATION=false

# Database resilience
DB_RETRY_LOGIC=false

# Environment
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/jobPortal

# JWT
JWT_SECRET=your-jwt-secret-key

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Service (for future use)
EMAIL_SERVICE_API_KEY=
EMAIL_FROM_ADDRESS=

# SMS Service (for future use)
SMS_SERVICE_API_KEY=
SMS_FROM_NUMBER=

# OTP Auth (passwordless login/signup)
OTP_TTL_MS=300000
OTP_RATE_WINDOW_MS=300000
OTP_MAX_REQUESTS_PER_WINDOW=3
OTP_MAX_ATTEMPTS=5
OTP_AUTO_SIGNUP=true
OTP_EXPOSE_IN_RESPONSE=true
OTP_HMAC_SECRET=replace-with-strong-random-secret
